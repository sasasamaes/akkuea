# Local Development Deployment Configuration
# Network Settings
STELLAR_NETWORK=standalone
STELLAR_RPC_URL=http://localhost:8000/soroban/rpc
STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
STELLAR_HORIZON_URL=http://localhost:8000

# Contract Configuration
CONTRACT_WASM_NAME=rwa_defi_contract.wasm
CONTRACT_BUILD_TARGET=wasm32-unknown-unknown

# Deployment Settings
DEPLOYMENT_ACCOUNT_NAME=local-dev
DEPLOYMENT_MIN_BALANCE=1000000
DEPLOYMENT_FEE_LIMIT=50000

# Post-Deployment
VERIFY_DEPLOYMENT=true
RUN_SMOKE_TESTS=true
SAVE_DEPLOYMENT_INFO=true
DEPLOYMENT_INFO_DIR=./deployed-contracts

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/deployment-local.log
