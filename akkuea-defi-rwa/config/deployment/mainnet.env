# Mainnet Deployment Configuration
# Network Settings
STELLAR_NETWORK=mainnet
STELLAR_RPC_URL=https://rpc.mainnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon.stellar.org

# Contract Configuration
CONTRACT_WASM_NAME=rwa_defi_contract.wasm
CONTRACT_BUILD_TARGET=wasm32-unknown-unknown

# Deployment Settings
DEPLOYMENT_ACCOUNT_NAME=mainnet-deployer
DEPLOYMENT_MIN_BALANCE=20000000
DEPLOYMENT_FEE_LIMIT=500000

# Post-Deployment
VERIFY_DEPLOYMENT=true
RUN_SMOKE_TESTS=true
SAVE_DEPLOYMENT_INFO=true
DEPLOYMENT_INFO_DIR=./deployed-contracts

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/deployment-mainnet.log

# Security
REQUIRE_CONFIRMATION=true
DRY_RUN_FIRST=true
