# Testnet Deployment Configuration
# Network Settings
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract Configuration
CONTRACT_WASM_NAME=rwa_defi_contract.wasm
CONTRACT_BUILD_TARGET=wasm32-unknown-unknown

# Deployment Settings
DEPLOYMENT_ACCOUNT_NAME=default
DEPLOYMENT_MIN_BALANCE=10000000
DEPLOYMENT_FEE_LIMIT=100000

# Post-Deployment
VERIFY_DEPLOYMENT=true
RUN_SMOKE_TESTS=true
SAVE_DEPLOYMENT_INFO=true
DEPLOYMENT_INFO_DIR=./deployed-contracts

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/deployment-testnet.log
