{
  "name": "l-estate-defi-platform",
  "version": "1.0.0",
  "description": "Real Estate Tokenization and DeFi Lending Platform on Stellar",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/shared",
    "apps/webapp"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:webapp\" \"bun run dev:api\"",
    "dev:webapp": "cd apps/webapp && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build": "concurrently \"bun run build:api\" \"bun run build:webapp\" \"bun run build:shared\"",
    "build:webapp": "cd apps/webapp && bun run build",
    "build:api": "cd apps/api && bun run build",
    "build:shared": "cd apps/shared && bun run build",
    "build:contracts": "./scripts/build.sh",
    "test": "bun test --workspaces",
    "lint": "concurrently \"cd apps/api && bun run lint\" \"cd apps/webapp && bun run lint\" \"cd apps/shared && bun run lint\"",
    "typecheck": "concurrently \"cd apps/api && bun run type-check\" \"cd apps/webapp && bun run type-check\" \"cd apps/shared && bun run type-check\"",
    "type-check": "concurrently \"cd apps/api && bun run type-check\" \"cd apps/webapp && bun run type-check\" \"cd apps/shared && bun run type-check\"",
    "clean": "bun run clean --workspaces && rm -rf node_modules",
    "install:all": "bun install && bun install --workspaces",
    "deploy:contracts": "./scripts/deploy.sh",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,rs}\" \"!apps/contracts/**\""
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@hookform/resolvers": "^5.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "react-hook-form": "^7.71.2",
    "soroban-client": "^1.0.1",
    "stellar-sdk": "^13.3.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.0.0",
  "overrides": {
    "ajv": "^6.14.0",
    "flatted": "^3.4.0",
    "axios": "^1.13.5",
    "file-type": "^21.3.4",
    "minimatch": ">=10.2.1",
    "eslint-visitor-keys": "^5.0.1"
  }
}
